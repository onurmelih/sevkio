# Bu dosyayı .env olarak kopyala ve kendi değerlerini gir (yerel test için).
# Vercel'de bunları panelden "Environment Variables" kısmına gireceksin.

# Supabase: Project Settings -> Database -> Connection string -> "Connection pooling" -> URI
# (port 6543 olan pooler adresini kullan, sunucusuz ortamlar için gerekli)
DATABASE_URL=postgresql://postgres.xxxxx:senin-supabase-sifren@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
JWT_SECRET=buraya-uzun-rastgele-bir-anahtar-yaz

# Bu ikisi tanımlıysa, sunucu ilk açılışta otomatik olarak bir süper admin hesabı oluşturur.
# Kendi bilgilerinle değiştir, /superadmin.html adresinden bu bilgilerle giriş yaparsın.
SUPERADMIN_EMAIL=sen@ornek.com
SUPERADMIN_PASSWORD=guclu-bir-sifre-belirle
